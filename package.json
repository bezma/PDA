{
  "name": "pda-capris",
  "version": "1.0.0",
  "private": true,
  "description": "Capris PDA shared database server",
  "main": "server.js",
  "scripts": {
    "check": "node --check server.js && node --check public/js/script.js && node --check public/js/pda-database.js",
    "migrate": "node scripts/migrate.js up",
    "migrate:status": "node scripts/migrate.js status",
    "start": "npm run migrate && node server.js",
    "dev": "node --watch server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pg": "^8.16.3"
  }
}
